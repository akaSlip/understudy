{
  "name": "understudy",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Offline-first line-rehearsal PWA: a TTS scene partner that performs the other characters, waits for your lines, and scores them in real time.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host",
    "typecheck": "tsc --noEmit",
    "test:unit": "esbuild src/dev/smoke.ts --bundle --format=esm --platform=node --external:kokoro-js --external:@huggingface/transformers --external:pdfjs-dist --external:pdfjs-dist/* --external:tesseract.js --external:microsoft-cognitiveservices-speech-sdk --outfile=node_modules/.cache/understudy-smoke.mjs && node node_modules/.cache/understudy-smoke.mjs",
    "test:engine": "esbuild src/dev/engineSmoke.ts --bundle --format=esm --platform=node --external:kokoro-js --external:@huggingface/transformers --external:pdfjs-dist --external:pdfjs-dist/* --external:tesseract.js --external:microsoft-cognitiveservices-speech-sdk --outfile=node_modules/.cache/understudy-engine.mjs && node node_modules/.cache/understudy-engine.mjs",
    "test": "npm run typecheck && npm run test:unit && npm run test:engine",
    "package": "npm run build && tar -czf understudy-app.tar.gz -C dist . && ls -lh understudy-app.tar.gz"
  },
  "dependencies": {
    "@fontsource-variable/fraunces": "^5.2.9",
    "@fontsource-variable/outfit": "^5.2.8",
    "@huggingface/transformers": "^4.2.0",
    "dexie": "^4.0.11",
    "double-metaphone": "^2.0.1",
    "kokoro-js": "^1.2.1",
    "microsoft-cognitiveservices-speech-sdk": "^1.50.0",
    "pdfjs-dist": "^4.10.38",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tesseract.js": "^5.1.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vite-plugin-pwa": "^0.21.1"
  },
  "overrides": {
    "uuid": "^11.1.1",
    "onnxruntime-node": "file:./stubs/empty-stub",
    "sharp": "file:./stubs/empty-stub",
    "@napi-rs/canvas": "file:./stubs/empty-stub"
  }
}